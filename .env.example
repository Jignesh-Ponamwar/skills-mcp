# ── Qdrant Cloud (required) ───────────────────────────────────────────────────
# Create a free cluster at https://cloud.qdrant.io
# Copy the cluster URL and an API key from the dashboard.
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Cloudflare (required) ─────────────────────────────────────────────────────
# Account ID: Cloudflare dashboard → right sidebar → "Account ID"
# API Token:  dash.cloudflare.com/profile/api-tokens → Create Token
#             Required permissions: "Workers AI Run" + "Workers Scripts Edit"
#
# Used by the seed script to call Workers AI for embeddings.
# The deployed Worker uses its AI binding (set in wrangler.jsonc) — no token needed there.
WORKERS_AI_ACCOUNT_ID=your_cloudflare_account_id_here
WORKERS_AI_API_TOKEN=your_cloudflare_api_token_here

# ── Collection names (optional — only change if you renamed them in Qdrant) ───
FRONTMATTER_COLLECTION=skill_frontmatter
BODY_COLLECTION=skill_body
OPTIONS_COLLECTION=skill_options

# ── Local Python server (optional — only if running skill_mcp.server locally) ─
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
