# =============================================================================
# Docker Build Context Exclusions
# =============================================================================
# Files excluded from Docker image builds to reduce image size

# =============================================================================
# N8N AUTOMATION (Development only - not needed in production image)
# =============================================================================
n8n/
n8n/node_modules/
n8n/.env
n8n/.env.local
n8n/.n8n/
n8n/database.sqlite
n8n/cache/
n8n/logs/

# =============================================================================
# VERSION CONTROL & DOCUMENTATION (Not runtime dependencies)
# =============================================================================
.git/
.gitignore
.github/
.gitlab-ci.yml
.circleci/
docs/
*.md
CONTRIBUTING.md
LICENSE
CHANGELOG.md

# =============================================================================
# DEVELOPMENT & TEST FILES
# =============================================================================
.venv/
venv/
env/
*.pyc
__pycache__/
.pytest_cache/
.coverage
.mypy_cache/
.dmypy.json
*.log

# =============================================================================
# NODE & PACKAGE MANAGERS (If not needed in final build)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# IDE & EDITOR FILES
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace

# =============================================================================
# OS ARTIFACTS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# BUILD ARTIFACTS & TEMPORARY FILES
# =============================================================================
.claude/
.cache/
tmp/
temp/
dist/
build/
*.bak
*.tmp
*.temp
*.orig

# =============================================================================
# SECRETS (Never in Docker image)
# =============================================================================
.env
.env.local
.env.*.local
.wrangler/
*.pem
*.key
*.secret
.secret
